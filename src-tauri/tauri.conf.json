{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kopipe",
  "version": "0.1.0",
  "identifier": "io.github.lakepuka.kopipe",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "kopipe",
        "width": 580,
        "height": 540,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "lakepuka",
    "copyright": "© 2026 lakepuka",
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
